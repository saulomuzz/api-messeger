# ── Modo Desenvolvedor ───────────────────────────────────
# Quando true, TODOS os envios são redirecionados para DEV_TEST_PHONE.
# Mensagens de texto recebem prefixo "[DEV → <destinatário original>]".
# Nunca ative em produção!
DEV_MODE_ENABLED=false
DEV_TEST_PHONE=

PORT=3000
SQLITE_PATH=./data/app.sqlite
# Vazio (padrao) = CORS desabilitado, nao afeta chamadas servidor-a-servidor.
# Se algum frontend em outro dominio precisar chamar essa API direto do
# navegador com cookie de sessao, liste as origens separadas por virgula,
# ex: https://painel.exemplo.com,https://outro.exemplo.com
CORS_ORIGIN=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now
ADMIN_SESSION_HOURS=24

WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# App Secret do app Meta (App Dashboard > Configurações básicas). Usado para
# validar a assinatura X-Hub-Signature-256 dos eventos do webhook. Sem isso
# configurado, qualquer requisição POST /webhook/whatsapp é aceita sem checar
# se veio de fato da Meta (fica só um aviso no log).
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_WEBHOOK_DOMAIN=

ABUSEIPDB_API_KEY=
GLOBAL_IP_ALLOWLIST=
SECURITY_YELLOW_THRESHOLD=25
SECURITY_BLOCK_THRESHOLD=75
SECURITY_REPUTATION_TTL_MINUTES=1440
SECURITY_GLOBAL_RATE_LIMIT_PER_MINUTE=120
